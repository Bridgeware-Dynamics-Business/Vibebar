{
  "name": "vibe-code-toolbar",
  "version": "1.0.0",
  "private": true,
  "description": "VibeBar — a floating Windows overlay companion for vibe coders: project-aware prompt library, secret scanner, context packer, and continuous AI-context folder sync.",
  "author": "Bridgeware Dynamics Business",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w vibebar",
    "build": "npm run build -w vibebar",
    "dist": "npm run dist -w vibebar",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.8"
  }
}
