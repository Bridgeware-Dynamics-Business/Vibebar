{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ES2023"],
    "baseUrl": ".",
    "paths": {
      "@vibebar/codesync/api": ["../../packages/codesync/src/api.ts"],
      "@vibebar/codesync": ["../../packages/codesync/src/index.ts"],
      "@vibebar/project-detector": ["../../packages/project-detector/src/index.ts"],
      "@vibebar/prompt-engine": ["../../packages/prompt-engine/src/index.ts"],
      "@vibebar/prompt-packs": ["../../packages/prompt-packs/src/index.ts"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "electron.vite.config.ts"
  ]
}
