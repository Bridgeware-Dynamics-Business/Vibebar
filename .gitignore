# ---------------------------------------------------------------------------
# Vibe Code Toolbar — .gitignore
# Stack: npm workspaces monorepo · Electron (electron-vite + electron-builder)
#        React + TailwindCSS · TypeScript · Vitest
# ---------------------------------------------------------------------------

# --- Dependencies ----------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Build output ----------------------------------------------------------
out/
dist/
dist-ssr/
build/
debug-out/
debug-out-*/
debug-*.mjs
temp-out.js
temp-main.js
release/
release-builds/
app-builds/
packages/*/lib/
packages/*/dist/

# Track the VibeBar app icon: apps/vibebar/build holds electron-builder's buildResources
# (the packaging icon), which is source input — NOT build output — and must be version
# controlled so it can never be lost again. The broad `build/` rule above would otherwise
# ignore it.
!apps/vibebar/build/
!apps/vibebar/build/**

# electron-builder packaging artifacts (installers, unpacked apps, blockmaps)
*.exe
*.msi
*.dmg
*.pkg
*.deb
*.rpm
*.AppImage
*.snap
*.blockmap
*.nsis.7z
*.zip
builder-effective-config.yaml
builder-debug.yml

# --- Caches / intermediate -------------------------------------------------
.vite/
.turbo/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
tsconfig.tsbuildinfo

# --- Tests / coverage ------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# --- Logs ------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Native modules / node-gyp ---------------------------------------------
build/Release/
prebuilds/
*.node

# --- Environment / secrets — never commit ---------------------------------
.env
.env.*
!.env.example
*.local
*.pem
*.key
*.p12
*.pfx
*.keystore
secrets.json
credentials.json

# --- Editor / IDE ----------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~

# --- OS --------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Code Sync mirror outputs & duplicate working trees --------------------
# "AI Context/" is the default Code Sync mirror destination — a generated,
# one-way copy of project files (carries its own node_modules/out/release).
# "Vibebar/" is a full duplicate working tree that even contains its own
# nested .git repository. Neither is source: keep both out of the repo so the
# initial commit stays clean (git would otherwise add Vibebar/ as a gitlink).
/AI Context/
/Vibebar/

# Defensive: ignore these mirror artifacts even if they appear nested
**/AI Context/**/node_modules/
**/AI Context/**/out/
**/AI Context/**/dist/
**/AI Context/**/release/

# VibeBar notes (local only)
Notes/

# VibeBar session timeline (local only)
.vibebar/
